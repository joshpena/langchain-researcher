# LLM Providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Web Search - Tavily (free tier: 1000 searches/month)
# Get your key at https://tavily.com
TAVILY_API_KEY=

# Email - Resend (optional, for email notifications)
# Get your key at https://resend.com
# Recipients enter their email in the UI; only the sender/API key are configured here.
RESEND_API_KEY=
REPORT_EMAIL_FROM=
